# Copy to .env and fill in what you need. Values already set in the shell
# environment take precedence over this file.

# --- OpenAI-compatible endpoint (primary configuration) ---
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_TEMPERATURE=0.1
# OPENAI_TIMEOUT_SECONDS=120
# OPENAI_MAX_RETRIES=3

# --- Review behavior ---
# REVIEW_MAX_CHUNK_CHARS=8000
# REVIEW_MAX_WORKERS=4
# Language for findings (reason/recommendation): zh, en, or a language name.
# REVIEW_LANGUAGE=zh

# --- Alternative: AIHubMix-style variables (used when OPENAI_* are unset) ---
# AIHUBMIX_API_KEY=
# AIHUBMIX_BASE_URL=https://aihubmix.com/v1
# AIHUBMIX_MODEL=gpt-4o-mini

# --- Keyring lookup (used when no API key is found in the environment) ---
# Store a key with: python scripts/review_document.py store-key
# AIHUBMIX_KEYRING_SERVICE=doc-review-agent
# AIHUBMIX_KEYRING_USERNAME=api-key
